<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title><%= clase.nombre_clase %> | MaxGrade</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://kit.fontawesome.com/101326ea39.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="/public/style.css">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom sticky-top">
        <div class="container-fluid">
            <a class="btn btn-light me-2" href="/dashboard"><i class="fa-solid fa-arrow-left"></i></a>
            <span class="navbar-brand fw-bold"><%= clase.nombre_clase %></span>
            
            <div class="mx-auto">
                <ul class="nav nav-underline">
                    <li class="nav-item"><a class="nav-link active" href="#">Novedades</a></li>
                    <li class="nav-item"><a class="nav-link text-dark" href="/clase/<%= clase.id %>/tareas">Trabajo en clase</a></li>
                    <li class="nav-item"><a class="nav-link text-dark" href="/clase/<%= clase.id %>/personas">Personas</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="container mt-4" style="max-width: 900px;">
        <div class="p-5 mb-4 rounded-3 text-white shadow-sm" style="background: linear-gradient(135deg, #1a73e8, #0d47a1); min-height: 200px;">
            <div class="container-fluid py-5">
                <h1 class="display-5 fw-bold"><%= clase.nombre_clase %></h1>
                <p class="fs-4"><%= clase.seccion %></p>
                <div class="badge bg-light text-dark px-3 py-2">Código de clase: <strong><%= clase.codigo_acceso %></strong></div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-3 d-none d-md-block">
                <div class="card border-0 shadow-sm p-3 mb-4">
                    <h6 class="fw-bold">Próximas entregas</h6>
                    <p class="small text-muted">¡No tienes tareas para esta semana!</p>
                    <a href="#" class="btn btn-link btn-sm p-0 text-decoration-none">Ver todo</a>
                </div>
            </div>

            <div class="col-md-9">
                <div class="card border-0 shadow-sm mb-4 p-3">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-primary text-white rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                            <%= (user && user.nombre) ? user.nombre.charAt(0).toUpperCase() : 'U' %>
                        </div>
                        <button class="btn btn-outline-secondary w-100 text-start rounded-pill py-2" data-bs-toggle="collapse" data-bs-target="#postForm">
                            Anuncia algo a tu clase...
                        </button>
                    </div>

                    <div class="collapse mt-2" id="postForm">
                        <textarea id="postContent" class="form-control mb-2" rows="3" placeholder="Escribe tu mensaje aquí..."></textarea>
                        <div class="text-end">
                            <button class="btn btn-light btn-sm" data-bs-toggle="collapse" data-bs-target="#postForm">Cancelar</button>
                            <button class="btn btn-primary btn-sm px-4" onclick="createPost('<%= clase.id %>')">Publicar</button>
                        </div>
                    </div>
                </div>

                <div id="postsList">
                    <% if (posts.length === 0) { %>
                        <div class="text-center py-5">
                            <i class="fa-solid fa-newspaper fa-3x text-muted opacity-25 mb-3"></i>
                            <p class="text-muted">Aquí aparecerán los anuncios de la clase.</p>
                        </div>
                    <% } else { %>
                        <% posts.forEach(post => { %>
                            <div class="card border-0 shadow-sm mb-3">
                                <div class="card-body">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="bg-secondary text-white rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                            <%= post.autor_nombre.charAt(0) %>
                                        </div>
                                        <div>
                                            <h6 class="mb-0 fw-bold"><%= post.autor_nombre %></h6>
                                            <small class="text-muted"><%= new Date(post.fecha_publicacion).toLocaleDateString() %></small>
                                        </div>
                                    </div>
                                    <p class="card-text"><%= post.contenido %></p>
                                </div>
                            </div>
                        <% }) %>
                    <% } %>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/public/js/clase.js"></script>
</body>
</html>