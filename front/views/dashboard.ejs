<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>MaxGrade | Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/public/style.css">
    <script src="https://kit.fontawesome.com/your-code.js"></script>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand" href="#">
                <img src="/public/img/LogoPng.png" width="30" alt="Logo"> MaxGrade
            </a>
            <div class="d-flex align-items-center">
                <div class="dropdown me-3">
                    <button class="btn btn-light rounded-circle" type="button" data-bs-toggle="dropdown">
                        <i class="fa-solid fa-plus"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#joinModal">Unirse a una clase</a></li>
                        <li><a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#createModal">Crear una clase</a></li>
                    </ul>
                </div>
                <div class="user-avatar bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">
                    <%= user.nombre.charAt(0) %>
                </div>
            </div>
        </div>
    </nav>

    <main class="container mt-4">
        <div class="row">
            <% if (clases.length === 0) { %>
                <div class="text-center mt-5">
                    <img src="/public/img/empty.png" style="max-width: 200px; opacity: 0.5;">
                    <p class="text-muted mt-3">Haz clic en el botón "+" para empezar</p>
                </div>
            <% } else { %>
                <% clases.forEach(clase => { %>
                    <div class="col-md-4 col-lg-3 mb-4">
                        <div class="card h-100 class-card shadow-sm">
                            <div class="class-header p-3 text-white" style="background-color: <%= clase.color_tema %>; height: 100px; border-radius: 4px 4px 0 0;">
                                <h5 class="card-title text-truncate"><%= clase.nombre_clase %></h5>
                                <p class="small"><%= clase.seccion %></p>
                            </div>
                            <div class="card-body d-flex flex-column justify-content-between">
                                <p class="small text-muted">Profesor: <%= clase.profesor_nombre %></p>
                                <div class="text-end">
                                    <a href="/class/<%= clase.id %>" class="btn btn-sm btn-outline-secondary">Ver clase</a>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </main>

    <div class="modal fade" id="joinModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form action="/api/classes/join" method="POST">
                    <div class="modal-header"><h5>Unirse a la clase</h5></div>
                    <div class="modal-body">
                        <p class="small text-muted">Pídele el código de la clase al profesor e introdúcelo aquí.</p>
                        <input type="text" name="codigo_acceso" class="form-control" placeholder="Código de la clase" required>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Unirse</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="createModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form action="/api/classes/create" method="POST">
                    <div class="modal-header"><h5>Crear clase</h5></div>
                    <div class="modal-body">
                        <input type="text" name="nombre_clase" class="form-control mb-3" placeholder="Nombre de la clase (obligatorio)" required>
                        <input type="text" name="seccion" class="form-control mb-3" placeholder="Sección">
                        <input type="text" name="materia" class="form-control" placeholder="Materia">
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Crear</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>