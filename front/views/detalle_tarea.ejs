<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title><%= tarea.titulo %> | MaxGrade</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://kit.fontawesome.com/101326ea39.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="/public/style.css">
</head>
<body class="bg-light">

    <nav class="navbar navbar-light bg-white border-bottom sticky-top">
        <div class="container">
            <a class="btn btn-light me-2" href="/clase/<%= tarea.clase_id %>/tareas"><i class="fa-solid fa-arrow-left"></i></a>
            <span class="navbar-brand fw-bold">Tarea</span>
        </div>
    </nav>

    <main class="container mt-5" style="max-width: 1000px;">
        <div class="row">
            <div class="col-md-8">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-primary text-white rounded-circle p-3 me-3">
                        <i class="fa-solid fa-clipboard-list fa-2x"></i>
                    </div>
                    <div>
                        <h1 class="h3 mb-0"><%= tarea.titulo %></h1>
                        <p class="text-muted small mb-0">
                            <%= tarea.profesor.nombre %> <%= tarea.profesor.apellido %> • <%= new Date(tarea.fecha_creacion).toLocaleDateString() %>
                        </p>
                        <div class="d-flex justify-content-between border-bottom pb-2 mt-2">
                            <span class="fw-bold small"><%= tarea.puntos_maximos %> puntos&ensp;&ensp;&ensp;&ensp;&ensp;&ensp;&ensp;&ensp;&ensp;&ensp;&ensp;&ensp;&ensp;</span>
                            <small>
                                Fecha de entrega: <%= new Date(tarea.fecha_entrega).toLocaleDateString('es-ES') %>
                            </small>
                        </div>
                    </div>
                </div>

                <div class="mt-4">
                    <p><%= tarea.instrucciones %></p>
                </div>

                <% if (tarea.archivo_guia_url) { %>
                    <div class="mt-4">
                        <h6 class="fw-bold">Materiales de apoyo</h6>
                        <a href="<%= tarea.archivo_guia_url %>" target="_blank" class="card d-inline-block text-decoration-none border shadow-sm p-3" style="max-width: 300px;">
                            <div class="d-flex align-items-center">
                                <i class="fa-solid fa-file-pdf fa-2x text-danger me-3"></i>
                                <span class="text-dark text-truncate">Ver material adjunto</span>
                            </div>
                        </a>
                    </div>
                <% } %>
            </div>

            <div class="col-md-4">
                <% if (rol === 'profesor') { %>
                    <div class="card shadow-sm border-0 p-3">
                        <h5 class="fw-bold mb-3">Entregas de estudiantes</h5>
                        <a href="/tarea/<%= tarea.id %>/revision" class="btn btn-primary w-100 mb-3">Ver y calificar entregas</a>
                        <% if (entregas && entregas.length > 0) { %>
                            <% entregas.forEach(entrega => { %>
                                <div class="d-flex align-items-center justify-content-between mb-2 p-2 border rounded">
                                    <div>
                                        <strong><%= entrega.estudiante.nombre %> <%= entrega.estudiante.apellido %></strong>
                                        <br>
                                        <small class="text-muted">Entregado: <%= new Date(entrega.fecha_entrega).toLocaleDateString() %></small>
                                    </div>
                                    <a href="<%= entrega.archivo_entrega_url %>" target="_blank" class="btn btn-sm btn-outline-primary">Ver</a>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p class="text-muted">No hay entregas aún.</p>
                        <% } %>
                    </div>
                <% } else { %>
                    <div class="card shadow-sm border-0 p-3">
                        <h5 class="fw-bold mb-3">Tu trabajo</h5>
                        
                        <% if (entrega) { %>
                            <div class="alert alert-success small">Tarea entregada</div>
                            <a href="<%= entrega.archivo_entrega_url %>" target="_blank" class="btn btn-outline-secondary w-100 mb-2">Ver mi entrega</a>
                        <% } else { %>
                            <form id="submissionForm">
                                <div class="mb-3">
                                    <label class="btn btn-outline-primary w-100 py-3 border-dashed">
                                        <i class="fa-solid fa-plus me-2"></i> Añadir o crear
                                        <input type="file" id="submissionFile" hidden required>
                                    </label>
                                    <div id="fileNameDisplay" class="small text-muted mt-2 text-center"></div>
                                </div>
                                <button type="button" class="btn btn-primary w-100 py-2" onclick="submitWork('<%= tarea.id %>')">Marcar como entregada</button>
                            </form>
                        <% } %>
                    </div>
                <% } %>
            </div>
        </div>
    </main>

    <script src="/public/js/entrega.js"></script>
</body>
</html>