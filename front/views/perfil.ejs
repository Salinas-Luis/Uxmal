<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Mi Perfil | MaxGrade</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://kit.fontawesome.com/101326ea39.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="/public/style.css">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom sticky-top">
        <div class="container">
            <a class="btn btn-light me-2" href="/dashboard"><i class="fa-solid fa-arrow-left"></i> Volver</a>
            <span class="navbar-brand fw-bold">Configuración de Perfil</span>
        </div>
    </nav>

    <main class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="card shadow-sm border-0 overflow-hidden">
                    <div class="bg-primary" style="height: 100px;"></div>
                    
                    <div class="card-body text-center" style="margin-top: -50px;">
                        <div class="position-relative d-inline-block mb-3">
                            <img src="<%= user.avatar_url || '/public/img/default-avatar.png' %>" 
                                 id="profileImage"
                                 class="rounded-circle border border-4 border-white shadow-sm" 
                                 style="width: 120px; height: 120px; object-fit: cover;">
                            <label for="avatarInput" class="btn btn-sm btn-dark rounded-circle position-absolute bottom-0 end-0">
                                <i class="fa-solid fa-camera"></i>
                                <input type="file" id="avatarInput" hidden accept="image/*" onchange="updateAvatar()">
                            </label>
                        </div>

                        <h3 class="fw-bold mb-0"><%= user.nombre %> <%= user.apellido %></h3>
                        <p class="text-muted"><%= user.email %></p>
                        
                        <hr class="my-4">

                        <div class="text-start">
                            <h6 class="fw-bold mb-3">Detalles de la cuenta</h6>
                            <div class="mb-3">
                                <label class="small text-muted">Nombre completo</label>
                                <input type="text" class="form-control" value="<%= user.nombre %> <%= user.apellido %>" readonly>
                            </div>
                            <div class="mb-3">
                                <label class="small text-muted">Correo electrónico</label>
                                <input type="email" class="form-control" value="<%= user.email %>" readonly>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button class="btn btn-outline-danger" onclick="logout()">
                                <i class="fa-solid fa-right-from-bracket me-2"></i> Cerrar Sesión
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="/public/js/perfil.js"></script>
</body>
</html>