<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MaxGrade | Crear Cuenta</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/public/style.css">
</head>
<body class="bg-light d-flex flex-column min-vh-100">

    <header class="bg-dark text-white shadow-sm">
        <nav class="navbar navbar-expand-lg navbar-dark container">
            <a class="navbar-brand" href="/">
                <img src="/public/img/maxgradeplacapng.png" alt="Logo MaxGrade" style="height: 40px;">
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
                <ul class="navbar-nav nav-underline">
                    <li class="nav-item me-lg-3">
                        <a class="nav-link text-white" href="#conocenos">Conócenos</a>
                    </li>
                    <li class="nav-item me-lg-3">
                        <a class="nav-link text-white" href="/login">Iniciar Sesión</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link btn btn-primary text-white px-3" href="/registro">Registrarse</a>
                    </li>
                </ul>
            </div>
        </nav>
    </header>

    <main class="flex-grow-1 d-flex align-items-center justify-content-center py-5">
        <div class="card shadow border-0 p-4" style="max-width: 450px; width: 100%;">
            <div class="text-center">
                <a href="/">
                    <img class="mb-3" src="/public/img/LogoPng.png" alt="Logo" width="72">
                </a>
                <h1 class="h3 mb-3 fw-bold text-primary">Únete a MaxGrade</h1>
                <p class="text-muted small">Crea tu cuenta para empezar a enseñar o aprender.</p>
            </div>

            <form id="registerForm">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <input type="text" class="form-control" id="nombre" placeholder="Nombre" required>
                            <label for="nombre">Nombre</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <input type="text" class="form-control" id="apellido" placeholder="Apellido" required>
                            <label for="apellido">Apellido</label>
                        </div>
                    </div>
                </div>

                <div class="form-floating mb-3">
                    <input type="email" class="form-control" id="email" placeholder="nombre@ejemplo.com" required>
                    <label for="email">Correo electrónico</label>
                </div>

                <div class="form-floating mb-3">
                    <input type="password" class="form-control" id="password" placeholder="Contraseña" required>
                    <label for="password">Contraseña</label>
                </div>

                <div id="errorMessage" class="alert alert-danger d-none" role="alert"></div>
                <div id="successMessage" class="alert alert-success d-none" role="alert">
                    ¡Registro exitoso! Redirigiendo...
                </div>

                <button class="w-100 btn btn-lg btn-primary shadow-sm" type="submit" id="regBtn">
                    Crear mi cuenta
                </button>
                
                <hr class="my-4">
                
                <p class="text-center text-muted mb-0">
                    ¿Ya tienes una cuenta? <a href="/login" class="text-decoration-none fw-bold">Inicia sesión</a>
                </p>
            </form>
        </div>
    </main>

    <footer class="bg-dark text-white py-4 mt-auto">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    <p class="mb-0 small opacity-75">© 2026 MaxGrade. Todos los derechos reservados.</p>
                </div>
                <div class="col-md-6 text-center text-md-end mt-3 mt-md-0">
                    <a href="#" class="text-white me-3 fs-5"><i class="fa-brands fa-instagram"></i></a>
                    <a href="#" class="text-white fs-5"><i class="fa-brands fa-facebook"></i></a>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/public/js/register.js"></script>
</body>
</html>