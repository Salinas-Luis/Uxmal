<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MaxGrade | Crear Cuenta</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/public/style.css">
</head>
<body class="bg-light d-flex align-items-center py-4" style="min-height: 100vh;">

    <main class="form-signin w-100 m-auto" style="max-width: 450px; padding: 15px;">
        <div class="card shadow border-0 p-4">
            <div class="text-center">
                <a href="/">
                    <img class="mb-3" src="/public/img/LogoPng.png" alt="Logo" width="72">
                </a>
                <h1 class="h3 mb-3 fw-bold text-primary">Únete a MaxGrade</h1>
                <p class="text-muted small">Crea tu cuenta para empezar a enseñar o aprender.</p>
            </div>

            <form id="registerForm">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <input type="text" class="form-control" id="nombre" placeholder="Nombre" required>
                            <label for="nombre">Nombre</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <input type="text" class="form-control" id="apellido" placeholder="Apellido" required>
                            <label for="apellido">Apellido</label>
                        </div>
                    </div>
                </div>

                <div class="form-floating mb-3">
                    <input type="email" class="form-control" id="email" placeholder="nombre@ejemplo.com" required>
                    <label for="email">Correo electrónico</label>
                </div>

                <div class="form-floating mb-3">
                    <input type="password" class="form-control" id="password" placeholder="Contraseña" required>
                    <label for="password">Contraseña</label>
                </div>

                <div id="errorMessage" class="alert alert-danger d-none" role="alert"></div>
                <div id="successMessage" class="alert alert-success d-none" role="alert">
                    ¡Registro exitoso! Redirigiendo...
                </div>

                <button class="w-100 btn btn-lg btn-primary shadow-sm" type="submit" id="regBtn">
                    Crear mi cuenta
                </button>
                
                <hr class="my-4">
                
                <p class="text-center text-muted">
                    ¿Ya tienes una cuenta? <a href="/login" class="text-decoration-none fw-bold">Inicia sesión</a>
                </p>
            </form>
        </div>
    </main>

    <script src="/public/js/register.js"></script>
</body>
</html>