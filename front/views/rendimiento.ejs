<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rendimiento | <%= clase.nombre_clase %> | MaxGrade</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://kit.fontawesome.com/101326ea39.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="/public/style.css">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom sticky-top">
        <div class="container-fluid">
            <a class="btn btn-light me-2" href="/clase/<%= clase.id %>"><i class="fa-solid fa-arrow-left"></i></a>
            <span class="navbar-brand fw-bold"><%= clase.nombre_clase %></span>
            
            <div class="mx-auto">
                <ul class="nav nav-underline">
                    <li class="nav-item"><a class="nav-link text-dark" href="/clase/<%= clase.id %>">Novedades</a></li>
                    <li class="nav-item"><a class="nav-link text-dark" href="/clase/<%= clase.id %>/tareas">Trabajo en clase</a></li>
                    <li class="nav-item"><a class="nav-link text-dark" href="/clase/<%= clase.id %>/personas">Personas</a></li>
                    <li class="nav-item"><a class="nav-link active" href="#">Rendimiento de clase</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="container mt-4" style="max-width: 900px;">
        <div class="p-5 mb-4 rounded-3 text-white shadow-sm position-relative overflow-hidden" 
             style="background-image: url('<%= clase.portada_url || '' %>');
                    background-color: #1a73e8; 
                    background-size: cover; 
                    background-position: center;
                    min-height: 200px;">
            <% if (clase.portada_url) { %>
                <div style="background: rgba(0,0,0,0.5); position: absolute; top: 0; left: 0; right: 0; bottom: 0;"></div>
            <% } %>
            <div class="container-fluid py-5 position-relative" style="z-index: 1;">
                <h1 class="display-5 fw-bold"><%= clase.nombre_clase %></h1>
                <p class="fs-4"><%= clase.seccion %></p>
            </div>
        </div>

        <% if (isProfesor && classPerformance) { %>
        <div class="mb-5">
            <h4 class="fw-bold mb-4">
                <i class="fa-solid fa-chart-line"></i> Rendimiento General de la Clase
            </h4>

            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex align-items-center justify-content-between">
                                <div>
                                    <p class="text-muted small mb-1">Promedio</p>
                                    <h3 class="mb-0 fw-bold"><%= classPerformance.promedioCalificacion %></h3>
                                </div>
                                <div class="bg-warning text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                    <i class="fa-solid fa-star fa-lg"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body">
                            <h6 class="card-title fw-bold mb-3">Distribución de Entregas</h6>
                            
                            <div class="mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="small">
                                        <span class="badge bg-success">A Tiempo</span>
                                        <%= classPerformance.entregadasAtiempo %>
                                    </span>
                                </div>
                                <div class="progress" style="height: 8px;">
                                    <div class="progress-bar bg-success" 
                                         style="width: <%= classPerformance.totalEntregas > 0 ? (classPerformance.entregadasAtiempo / classPerformance.totalEntregas * 100).toFixed(1) : 0 %>%"></div>
                                </div>
                            </div>

                            <div class="mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="small">
                                        <span class="badge bg-warning">Fuera de Plazo</span>
                                        <%= classPerformance.entregadasTarde %>
                                    </span>
                                </div>
                                <div class="progress" style="height: 8px;">
                                    <div class="progress-bar bg-warning" 
                                         style="width: <%= classPerformance.totalEntregas > 0 ? (classPerformance.entregadasTarde / classPerformance.totalEntregas * 100).toFixed(1) : 0 %>%"></div>
                                </div>
                            </div>

                            <div>
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="small">
                                        <span class="badge bg-danger">No Entregadas</span>
                                        <%= classPerformance.noEntregadas %>
                                    </span>
                                </div>
                                <div class="progress" style="height: 8px;">
                                    <div class="progress-bar bg-danger" 
                                         style="width: <%= classPerformance.noEntregadas > 0 ? (classPerformance.noEntregadas / (classPerformance.totalEstudiantes * classPerformance.totalTareas) * 100).toFixed(1) : 0 %>%"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body">
                            <h6 class="card-title fw-bold mb-3">Estado de Calificación</h6>
                            
                            <div class="list-group list-group-flush">
                                <div class="list-group-item px-0 py-2 d-flex justify-content-between align-items-center">
                                    <span class="small">Tareas Calificadas</span>
                                    <span class="badge bg-success rounded-pill"><%= classPerformance.totalEntregas - classPerformance.tareasSinCalificar %></span>
                                </div>
                                <div class="list-group-item px-0 py-2 d-flex justify-content-between align-items-center">
                                    <span class="small">Tareas Pendientes de Calificar</span>
                                    <span class="badge bg-warning rounded-pill"><%= classPerformance.tareasSinCalificar %></span>
                                </div>
                                <div class="list-group-item px-0 py-2 d-flex justify-content-between align-items-center">
                                    <span class="small">Total de Entregas Recibidas</span>
                                    <span class="badge bg-primary rounded-pill"><%= classPerformance.totalEntregas %></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <% } else if (!isProfesor) { %>
            <div class="alert alert-info" role="alert">
                <i class="fa-solid fa-circle-info"></i> El rendimiento de clase solo está disponible para profesores.
            </div>
        <% } %>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
